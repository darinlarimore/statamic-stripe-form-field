{
    "name": "darinlarimore/statamic-stripe-form-field",
    "autoload": {
        "psr-4": {
            "Darinlarimore\\StatamicStripeFormField\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Darinlarimore\\StatamicStripeFormField\\Tests\\": "tests"
        }
    },
    "require": {
        "statamic/cms": "^5.46",
        "stripe/stripe-php": "^16.5"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "Statamic Stripe Form Field",
            "description": "Statamic Stripe Form Field addon"
        },
        "laravel": {
            "providers": [
                "Darinlarimore\\StatamicStripeFormField\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "pestphp/pest": "*",
        "pestphp/pest-plugin-laravel": "*",
        "mockery/mockery": "*",
        "orchestra/testbench": "^9.0"
    },
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
